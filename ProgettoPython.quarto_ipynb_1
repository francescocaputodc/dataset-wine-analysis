    "#| echo: false\n",
    "#| fig-align: center\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# 1. Definizione delle variabili del gruppo\n",
    "gruppo_corpo = [\"Alcol\", \"Acido Malico\", \"Ceneri\", \"Alcalinità delle Ceneri\", \"Magnesio\"]\n",
    "\n",
    "# 2. Configurazione della figura e della griglia geometrica (2 righe, 6 colonne virtuali)\n",
    "fig = plt.figure(figsize=(9, 6.5))\n",
    "gs = fig.add_gridspec(2, 6, hspace=0.35, wspace=0.6)\n",
    "\n",
    "# 3. Mappatura manuale delle posizioni per centrare la seconda riga\n",
    "# Riga 1 (3 grafici): ognuno occupa 2 colonne virtuali (0-2, 2-4, 4-6)\n",
    "# Riga 2 (2 grafici): spostati a destra di 1 colonna per centrarli (1-3, 3-5)\n",
    "ax1 = fig.add_subplot(gs[0, 0:2])\n",
    "ax2 = fig.add_subplot(gs[0, 2:4])\n",
    "ax3 = fig.add_subplot(gs[0, 4:6])\n",
    "ax4 = fig.add_subplot(gs[1, 1:3]) # Centrato sotto\n",
    "ax5 = fig.add_subplot(gs[1, 3:5]) # Centrato sotto\n",
    "\n",
    "axes = [ax1, ax2, ax3, ax4, ax5]\n",
    "\n",
    "# 4. Generazione dei Boxplot nel ciclo\n",
    "for i, colonna in enumerate(gruppo_corpo):\n",
    "    sns.boxplot(\n",
    "        data=df_clean,\n",
    "        x=\"Vigneto\",\n",
    "        y=colonna,\n",
    "        hue=\"Vigneto\",\n",
    "        palette=\"Set2\",\n",
    "        ax=axes[i],\n",
    "        legend=False\n",
    "    )\n",
    "    \n",
    "    # Ottimizzazione estetica del singolo subplot\n",
    "    axes[i].set_title(colonna, fontsize=10.5, weight=\"bold\", pad=8)\n",
    "    axes[i].set_xlabel(\"Vigneto\", fontsize=8.5)\n",
    "    axes[i].set_ylabel(\"\") # Rimosso perché c'è già il titolo descrittivo sopra\n",
    "    axes[i].tick_params(axis=\"both\", labelsize=8)\n",
    "    axes[i].grid(axis=\"y\", linestyle=\"--\", alpha=0.5) # Griglia leggera di sfondo solo verticale\n",
    "\n",
    "# Titolo principale del blocco (opzionale, coordinato con i pairplot)\n",
    "fig.suptitle(\"1. Struttura e Proprietà Chimico-Fisiche\", fontsize=12, weight=\"bold\", y=0.96)\n",
    "\n",
    "plt.show()"
