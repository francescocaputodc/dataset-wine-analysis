    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "param_grid = {\n",
        "    \"hidden_layer_sizes\": [\n",
        "        (32,),\n",
        "        (50,),\n",
        "        (16, 8),\n",
        "        (32, 16),\n",
        "    ],\n",
        "    \"activation\": [\"relu\", \"tanh\"],\n",
        "    \"alpha\": [0.0001, 0.001, 0.01],\n",
