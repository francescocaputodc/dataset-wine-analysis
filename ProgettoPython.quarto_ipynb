    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Pairplot {.smaller}\n",
        "\n",
        "::: {.panel-tabset}\n",
        "\n",
        "### Chimico-Fisiche"
      ],
      "id": "f7404168"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: false\n",
        "#| fig-align: center\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "# Gruppo 1\n",
        "gruppo_corpo = [\"Alcol\", \"Acido Malico\", \"Ceneri\", \"Alcalinità delle Ceneri\", \"Magnesio\"]\n",
        "df_sub_1 = df_clean[gruppo_corpo + [\"Vigneto\"]]\n",
        "\n",
        "g1 = sns.pairplot(\n",
        "    df_sub_1,\n",
        "    x_vars=gruppo_corpo,\n",
        "    y_vars=gruppo_corpo[::-1],\n",
        "    hue=\"Vigneto\",\n",
        "    diag_kind=\"kde\",\n",
        "    palette=\"Set2\",\n",
        "    plot_kws={\"s\": 20, \"alpha\": 0.6},\n",
        "    height=1.5,\n",
        "    aspect=1,\n",
        ")\n",
        "\n",
        "# Ottimizzazione assi\n",
        "for ax in g1.axes.flatten():\n",
        "    if ax is not None:\n",
        "        ax.set_xlabel(ax.get_xlabel(), fontsize=8.5)\n",
        "        ax.set_ylabel(ax.get_ylabel(), fontsize=8.5)\n",
        "        ax.tick_params(axis=\"x\", labelsize=6.5)\n",
        "        ax.tick_params(axis=\"y\", labelsize=6.5)\n",
        "\n",
        "g1.fig.subplots_adjust(hspace=0.12, wspace=0.12, top=0.92)\n",
        "g1.fig.suptitle(\"1. Struttura e Proprietà Chimico-Fisiche\", fontsize=11, weight=\"bold\", y=0.97)\n",
        "g1._legend.remove()\n",
        "\n",
        "plt.show()"
      ],
