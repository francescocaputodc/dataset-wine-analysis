        "\n",
        "# 2. Configurazione della figura (Griglia perfetta 2x2)\n",
        "fig, axes = plt.subplots(nrows=2, ncols=2, figsize=(6.5, 6.5))\n",
        "axes = axes.flatten() # Appiattiamo la matrice 2x2 in un vettore per il ciclo for\n",
        "\n",
        "# 3. Generazione dei Boxplot nel ciclo\n",
        "for i, colonna in enumerate(gruppo_polifenoli):\n",
        "    sns.boxplot(\n",
        "        data=df_clean,\n",
        "        x=\"Vigneto\",\n",
        "        y=colonna,\n",
        "        hue=\"Vigneto\",\n",
        "        palette=\"Set2\",\n",
        "        ax=axes[i],\n",
        "        legend=False\n",
        "    )\n",
        "    \n",
        "    # Ottimizzazione estetica coerente con il primo gruppo\n",
        "    axes[i].set_title(colonna, fontsize=10, weight=\"bold\", pad=6)\n",
        "    axes[i].set_xlabel(\"Vigneto\", fontsize=8.5)\n",
        "    axes[i].set_ylabel(\"\") \n",
        "    axes[i].tick_params(axis=\"both\", labelsize=8)\n",
        "    axes[i].grid(axis=\"y\", linestyle=\"--\", alpha=0.4)\n",
        "\n",
        "# Titolo principale del secondo gruppo\n",
        "fig.suptitle(\"2. Profilo dei Polifenoli e Antiossidanti\", fontsize=11, weight=\"bold\", y=0.98)\n",
        "\n",
        "# Regolazione automatica degli spazi per non sovrapporre i titoli agli assi\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "bb98f742",
      "execution_count": null,
      "outputs": []
    },
