   "source": [
    "#|fig-align: center\n",
    "#|echo: false\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# 1. Definizione dei 3 gruppi logici di feature\n",
    "gruppo_corpo = [\n",
    "    \"alcohol\",\n",
    "    \"malic_acid\",\n",
    "    \"ash\",\n",
    "    \"alcalinity_of_ash\",\n",
    "    \"magnesium\",\n",
    "]\n",
    "gruppo_polifenoli = [\n",
    "    \"total_phenols\",\n",
    "    \"flavanoids\",\n",
    "    \"nonflavanoid_phenols\",\n",
    "    \"proanthocyanins\",\n",
    "]\n",
    "gruppo_visivo_bio = [\n",
    "    \"color_intensity\",\n",
    "    \"hue\",\n",
    "    \"od280/od315_of_diluted_wines\",\n",
    "    \"proline\",\n",
    "]\n",
    "\n",
    "I_tre_gruppi = [\n",
    "    (\"1. Struttura e Proprietà Chimico-Fisiche\", gruppo_corpo),\n",
    "    (\"2. Profilo dei Polifenoli e Antiossidanti\", gruppo_polifenoli),\n",
    "    (\"3. Caratteristiche Visive e Macromolecolari\", gruppo_visivo_bio),\n",
    "]\n",
    "\n",
    "# 2. Loop per generare i 3 pairplot separati\n",
    "for titolo, features in I_tre_gruppi:\n",
    "    # Creiamo il sotto-dataframe includendo sempre il target per il colore\n",
    "    df_sub_plot = df[features + [\"target\"]]\n",
    "\n",
    "    g = sns.pairplot(\n",
    "        df_sub_plot,\n",
    "        hue=\"target\",\n",
    "        diag_kind=\"kde\",\n",
    "        palette=\"Set2\",  # Un set di colori pulito e leggibile\n",
    "        plot_kws={\"s\": 25, \"alpha\": 0.6},  # Punti leggermente più grandi visto che c'è spazio\n",
    "        height=2.2,  # Aumentato per migliorarne la visualizzazione\n",
    "        aspect=1,\n",
    "    )\n",
    "\n",
    "    # Ottimizzazione delle etichette e dei font\n",
    "    for ax in g.axes.flatten():\n",
    "        if ax is not None:\n",
    "            ax.set_xlabel(ax.get_xlabel(), fontsize=9)\n",
    "            ax.set_ylabel(ax.get_ylabel(), fontsize=9)\n",
    "            ax.tick_params(axis=\"x\", labelsize=7)\n",
    "            ax.tick_params(axis=\"y\", labelsize=7)\n",
    "\n",
    "    # Spaziatura e titolo del blocco\n",
    "    g.fig.subplots_adjust(hspace=0.15, wspace=0.15, top=0.93)\n",
    "    g.fig.suptitle(titolo, fontsize=12, weight=\"bold\", y=0.98)\n",
    "\n",
    "    # Riposizioniamo la legenda in modo che non si sovrapponga\n",
    "    sns.move_legend(g, \"upper right\", bbox_to_anchor=(1.05, 0.9))\n",
    "\n",
    "    plt.show()"
   ]
